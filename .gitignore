## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools. If you are
## developing with Visual Studio, the VS .gitignore
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
## has more thorough IDE-specific entries.
##
## Get latest from https://github.com/github/gitignore/blob/main/Dotnet.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg

# Others
~$*
*~
CodeCoverage/

# MSBuild Binary and Structured Log
*.binlog

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Claude AI files
.claude/*

# Local app settings and environment variables
src/RecipeVault.WebApi/appsettings.local.json
.env

# Uploaded images (stored locally for now; move to cloud storage for production)
**/wwwroot/uploads/

# Visual Studio cache files
.vs/*

# Generated migration scripts (run generate-migration-sql.ps1)
migrate.sql
migrations/pending.sql

# Local documentation (not committed)
.local-docs/
docker-compose.qa.yml
docs/design/*
docs/implementation/*
src/RecipeVault.WebApi/appsettings.QA.json
supabase/config.toml

# Postman collections
*.postman_collection.json
*.postman_environment.json

# Build reports / summaries (use docs/ for persistent documentation)
*_SUMMARY.md
*_REPORT.md
*_STATUS.md
*-summary.md
CODE-REVIEW-*.md
SENTRY_FIXES_*.md
HANDOFF.md
QUICKSTART_*.md
