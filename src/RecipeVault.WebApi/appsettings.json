{
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http1AndHttp2"
    }
  },
  "Build": {
    "Version": "1.0.0-local",
    "Tag": "local"
  },
  "Service": {
    "Name": "recipevault-api"
  },
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "Seq": {
    "ServerUrl": ""
  },
  "Database": {
    "ConnectionString": ""
  },
  "Supabase": {
    "Url": "",
    "ServiceKey": "",
    "StorageBucket": "recipe-images",
    "Auth": {
      "JwtSecret": "",
      "Issuer": "",
      "Audience": "authenticated"
    }
  },
  "Gemini": {
    "ApiKey": "",
    "Model": "gemini-1.5-flash"
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Settings.Configuration"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Cortside.Health.HealthCheckHostedService": "Warning",
        "Cortside.Health.Checks": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{CorrelationId}][{RequestId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentUserName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "recipevault-api"
    }
  },
  "HealthCheckHostedService": {
    "Name": "{{Service:Name}}",
    "Enabled": true,
    "Interval": 5,
    "CacheDuration": 30,
    "Checks": [
      {
        "Name": "recipevault-db",
        "Type": "postgres",
        "Required": true,
        "Interval": 30,
        "Timeout": 5
      },
      {
        "Name": "gemini",
        "Type": "gemini",
        "Required": false,
        "Interval": 30,
        "Timeout": 5
      }
    ]
  },
  "Cors": {
    "Origins": ["http://localhost:4200", "https://localhost:4200"]
  },
  "Bowdlerizer": [
    {
      "Strategy": "head",
      "Path": "$..Recipe.OriginalImageUrl",
      "Length": 0
    }
  ]
}
